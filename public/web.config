<!--
    Rewrites requires Microsoft URL Rewrite Module for IIS
    Download: https://www.iis.net/downloads/microsoft/url-rewrite
-->
<configuration>
  <system.webServer>
    <!--
      Without Default Document, request "/" is treated as a physical directory.
      Rule 2 below skips rewrite when REQUEST_FILENAME IsDirectory → IIS returns
      its generic 403 (directory browsing disabled). /map works because that path
      is not a real folder. /index.php works because it is a real file.
    -->
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="index.php" />
      </files>
    </defaultDocument>
    <directoryBrowse enabled="false" />
    <rewrite>
      <rules>
        <!-- Always send bare "/" into Laravel (do not treat site root as a browsable dir). -->
        <rule name="Laravel Homepage" stopProcessing="true">
          <match url="^$" />
          <action type="Rewrite" url="index.php" />
        </rule>
        <rule name="Imported Rule 1" stopProcessing="true">
          <match url="^(.*)/$" ignoreCase="false" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" ignoreCase="false" negate="true" />
          </conditions>
          <action type="Redirect" redirectType="Permanent" url="/{R:1}" />
        </rule>
        <rule name="Imported Rule 2" stopProcessing="true">
          <match url="^" ignoreCase="false" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" ignoreCase="false" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsFile" ignoreCase="false" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.php" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>

<!--
    Rewrites requires Microsoft URL Rewrite Module for IIS
    Download: https://www.iis.net/downloads/microsoft/url-rewrite
-->
<configuration>
  <system.webServer>
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
    <httpCompression directory="%SystemDrive%\inetpub\temp\IIS Temporary Compressed Files">
      <scheme name="gzip" dll="%Windir%\system32\inetsrv\gzip.dll" />
      <scheme name="br" dll="%Windir%\system32\inetsrv\brotli.dll" />
      <dynamicTypes>
        <add mimeType="text/*" enabled="true" />
        <add mimeType="message/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/xml" enabled="true" />
        <add mimeType="image/svg+xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </dynamicTypes>
      <staticTypes>
        <add mimeType="text/*" enabled="true" />
        <add mimeType="message/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/xml" enabled="true" />
        <add mimeType="image/svg+xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </staticTypes>
    </httpCompression>
    <staticContent>
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>
    <httpProtocol>
      <customHeaders>
        <remove name="Cache-Control" />
      </customHeaders>
    </httpProtocol>
    <!--
      Without Default Document, request "/" is treated as a physical directory.
      Rule 2 below skips rewrite when REQUEST_FILENAME IsDirectory → IIS returns
      its generic 403 (directory browsing disabled). /map works because that path
      is not a real folder. /index.php works because it is a real file.
    -->
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="index.php" />
      </files>
    </defaultDocument>
    <directoryBrowse enabled="false" />
    <rewrite>
      <rules>
        <!-- Canonical host: non-www HTTPS only -->
        <rule name="Canonical WWW to non-WWW HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^www\.serik\.ca$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" redirectType="Permanent" url="https://serik.ca/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="Canonical HTTP to HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^serik\.ca$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" redirectType="Permanent" url="https://serik.ca/{R:1}" appendQueryString="true" />
        </rule>
        <!-- Block sensitive /public/ probes (never redirect framework paths) -->
        <rule name="Block Sensitive Public Prefix" stopProcessing="true">
          <match url="^public/(.+)$" ignoreCase="true" />
          <conditions logicalGrouping="MatchAny">
            <add input="{R:1}" pattern="^(\.env|vendor/|storage/|bootstrap/|config/|\.git|\.svn|composer\.(json|lock)|phpinfo\.php|wp-admin|wp-login\.php|xmlrpc\.php|adminer\.php|phpmyadmin|server-status|artisan|phpunit\.xml|package(-lock)?\.json|yarn\.lock|dockerfile|docker-compose\.ya?ml|web\.config|\.htaccess|\.htpasswd)" ignoreCase="true" />
            <add input="{R:1}" pattern="(^|/)\." ignoreCase="true" />
            <add input="{R:1}" pattern="\.(bak|backup|old|orig|save|swp|swo|sql|sqlite|db|dump|zip|tar|tgz|gz|bz2|7z|rar|log|ini|conf|sh|bash|pem|key)$" ignoreCase="true" />
          </conditions>
          <action type="CustomResponse" statusCode="404" statusReason="Not Found" statusDescription="Not Found" />
        </rule>
        <!-- Redirect harmless /public/... URLs to clean canonical paths -->
        <rule name="Redirect Public Prefix To Clean URL" stopProcessing="true">
          <match url="^public/?$" ignoreCase="true" />
          <action type="Redirect" redirectType="Permanent" url="/" appendQueryString="true" />
        </rule>
        <rule name="Redirect Public Prefix Path To Clean URL" stopProcessing="true">
          <match url="^public/(.*)$" ignoreCase="true" />
          <action type="Redirect" redirectType="Permanent" url="/{R:1}" appendQueryString="true" />
        </rule>
        <!-- Always send bare "/" into Laravel (do not treat site root as a browsable dir). -->
        <rule name="Laravel Homepage" stopProcessing="true">
          <match url="^$" />
          <action type="Rewrite" url="index.php" />
        </rule>
        <rule name="Imported Rule 1" stopProcessing="true">
          <match url="^(.*)/$" ignoreCase="false" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" ignoreCase="false" negate="true" />
          </conditions>
          <action type="Redirect" redirectType="Permanent" url="/{R:1}" />
        </rule>
        <rule name="Imported Rule 2" stopProcessing="true">
          <match url="^" ignoreCase="false" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" ignoreCase="false" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsFile" ignoreCase="false" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.php" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
  <location path="themes">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="public, max-age=31536000, immutable" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
  <location path="vendor">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="public, max-age=31536000, immutable" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
  <location path="storage">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="public, max-age=31536000, immutable" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>

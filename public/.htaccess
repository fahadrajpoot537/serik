# Compress API/JSON/text responses (map GeoJSON drops ~8x: 2MB -> ~256KB).
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json application/javascript text/javascript text/css text/html text/plain application/xml image/svg+xml application/geo+json
</IfModule>
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS application/json application/javascript text/javascript text/css text/html text/plain application/xml image/svg+xml application/geo+json
</IfModule>

<IfModule mod_rewrite.c>
    Options -Indexes

    RewriteEngine On

    # Canonical host: https://serik.ca (non-www)
    RewriteCond %{HTTP_HOST} ^www\.serik\.ca$ [NC]
    RewriteRule ^(.*)$ https://serik.ca/$1 [R=301,L]

    RewriteCond %{HTTP_HOST} ^serik\.ca$ [NC]
    RewriteCond %{HTTPS} !=on
    RewriteRule ^(.*)$ https://serik.ca/$1 [R=301,L]

    # Block sensitive /public/... probes (never redirect framework paths)
    RewriteRule ^public/((\.env|vendor/|storage/|bootstrap/|config/|\.git|\.svn).*)$ - [R=404,L,NC]
    RewriteRule ^public/(composer\.(json|lock)|phpinfo\.php|wp-admin|wp-login\.php|xmlrpc\.php|adminer\.php|phpmyadmin|server-status|artisan|phpunit\.xml|package(-lock)?\.json|yarn\.lock|dockerfile|docker-compose\.ya?ml|web\.config|\.htaccess|\.htpasswd)(/.*)?$ - [R=404,L,NC]
    RewriteRule ^public/.*(^|/)\. - [R=404,L]
    RewriteRule ^public/.*\.(bak|backup|old|orig|save|swp|swo|sql|sqlite|db|dump|zip|tar|tgz|gz|bz2|7z|rar|log|ini|conf|sh|bash|pem|key)$ - [R=404,L,NC]

    # Redirect harmless /public/... URLs to clean canonical paths
    RewriteRule ^public/?$ / [R=301,L]
    RewriteRule ^public/(.+)$ /$1 [R=301,L,QSA]

    # Block hidden files and common backup/archive probes inside public document root
    RewriteRule (^|/)\. - [F,L]
    RewriteRule \.(bak|backup|old|orig|save|swp|sql|sqlite|zip|tar|tgz|gz|7z|rar)$ - [F,L,NC]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>
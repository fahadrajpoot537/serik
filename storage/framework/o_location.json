{"error":false,"data":"<style>\r\n.grid-location{\r\n    display: grid;\r\n    grid-template-columns: repeat(4, 1fr);\r\n    gap: 20px;\r\n}\r\n\r\n\/* Tablet *\/\r\n@media (max-width: 991px){\r\n    .grid-location{\r\n        grid-template-columns: repeat(3, 1fr);\r\n    }\r\n}\r\n\r\n\/* Mobile (2 per row) *\/\r\n@media (max-width: 576px){\r\n    .grid-location{\r\n        grid-template-columns: repeat(2, 1fr);\r\n    }\r\n}\r\n\r\n\/* Make every card square *\/\r\n.box-location-v2 .box-img{\r\n    width:100%;\r\n    aspect-ratio:1 \/ 1;\r\n    overflow:hidden;\r\n    border-radius:12px;\r\n}\r\n\r\n\/* Image fit inside square *\/\r\n.box-location-v2 .box-img img{\r\n    width:100%;\r\n    height:100%;\r\n    object-fit:cover;\r\n}\r\n.tf-sw-locations {\r\n    overflow: hidden;\r\n}\r\n\r\n.tf-sw-locations .swiper-wrapper {\r\n    display: flex;\r\n}\r\n\r\n.tf-sw-locations .swiper-slide {\r\n    flex-shrink: 0;\r\n}\r\n<\/style>\r\n\r\n\r\n<section\r\n    class=\"flat-section flat-location-v2\" \r\n    style=\"\"\r\n>\r\n    <div class=\"container\">\r\n        <style>\r\n    @media (max-width: 768px) {\r\n    .button-prop {\r\n      display:none;\r\n    }\r\n}\r\n<\/style>\r\n\r\n\r\n\r\n        <div class=\"swiper tf-sw-locations wow fadeInUpSmall\"\r\n     data-wow-delay=\".4s\"\r\n     data-wow-duration=\"2000ms\">\r\n\r\n    <div class=\"swiper-wrapper\">\r\n\r\n                    <div class=\"swiper-slide\">\r\n                <a href=\"https:\/\/serik.ca\/on\/houses-for-sale-in-vaughan\/map\"\r\n                   class=\"box-location-v2 hover-img location-item\">\r\n\r\n                    <div class=\"box-img img-style\">\r\n                        <img src=\"https:\/\/serik.ca\/storage\/england-400x560.png\" data-bb-lazy=\"true\" loading=\"lazy\" alt=\"Vaughan\">\r\n                    <\/div>\r\n\r\n                    <div class=\"content\">\r\n                        <h3 class=\"link\" style=\"font-size: 20px;\">\r\n                            House for sale Vaughan\r\n                        <\/h3>\r\n                    <\/div>\r\n\r\n                <\/a>\r\n            <\/div>\r\n                    <div class=\"swiper-slide\">\r\n                <a href=\"https:\/\/serik.ca\/on\/houses-for-sale-in-oakville\/map\"\r\n                   class=\"box-location-v2 hover-img location-item\">\r\n\r\n                    <div class=\"box-img img-style\">\r\n                        <img src=\"https:\/\/serik.ca\/storage\/denmark-400x560.png\" data-bb-lazy=\"true\" loading=\"lazy\" alt=\"Oakville\">\r\n                    <\/div>\r\n\r\n                    <div class=\"content\">\r\n                        <h3 class=\"link\" style=\"font-size: 20px;\">\r\n                            House for sale Oakville\r\n                        <\/h3>\r\n                    <\/div>\r\n\r\n                <\/a>\r\n            <\/div>\r\n                    <div class=\"swiper-slide\">\r\n                <a href=\"https:\/\/serik.ca\/on\/houses-for-sale-in-toronto\/map\"\r\n                   class=\"box-location-v2 hover-img location-item\">\r\n\r\n                    <div class=\"box-img img-style\">\r\n                        <img src=\"https:\/\/serik.ca\/storage\/bavaria-400x560.png\" data-bb-lazy=\"true\" loading=\"lazy\" alt=\"Toronto\">\r\n                    <\/div>\r\n\r\n                    <div class=\"content\">\r\n                        <h3 class=\"link\" style=\"font-size: 20px;\">\r\n                            House for sale Toronto\r\n                        <\/h3>\r\n                    <\/div>\r\n\r\n                <\/a>\r\n            <\/div>\r\n        \r\n    <\/div>\r\n<\/div>\r\n\r\n\r\n    <\/div>\r\n<\/section>\r\n\r\n\r\n<script>\r\n function initLocationsSwiper() {\r\n    if (typeof Swiper === 'undefined') return;\r\n\r\n    const el = document.querySelector('.tf-sw-locations');\r\n    if (!el) return;\r\n\r\n    new Swiper(el, {\r\n        slidesPerView: 4,\r\n        spaceBetween: 20,\r\n        loop: true,\r\n\r\n        autoplay: {\r\n            delay: 2500,\r\n            disableOnInteraction: false,\r\n        },\r\n\r\n        speed: 800,\r\n\r\n        breakpoints: {\r\n            0: { slidesPerView: 2, spaceBetween: 10 },\r\n            576: { slidesPerView: 2, spaceBetween: 15 },\r\n            768: { slidesPerView: 2, spaceBetween: 20 },\r\n            992: { slidesPerView: 3, spaceBetween: 20 },\r\n            1200: { slidesPerView: 4, spaceBetween: 20 }\r\n        }\r\n    });\r\n}\r\n\r\n\/\/ run safely multiple times (fixes Laravel rendering issues)\r\nsetTimeout(initLocationsSwiper, 300);\r\nsetTimeout(initLocationsSwiper, 1000);\r\n<\/script>\r\n","message":null}
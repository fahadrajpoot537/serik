APP_NAME=Serik
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production canonical domain (non-www). Used for redirects, canonical tags, and sitemaps.
CANONICAL_URL=https://serik.ca
FORCE_ROOT_URL=https://serik.ca
FORCE_SCHEMA=https

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=serik
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=file

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

GEOCODING_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_GEOCODING_API_KEY=

# Geo block: public site only for listed ISO country codes (admin + map APIs bypass).
# Localhost/private IPs are always allowed for development.
GEO_BLOCK_ENABLED=true
GEO_BLOCK_ALLOWED_COUNTRIES=US,CA,PK
GEO_BLOCK_BYPASS_IPS=

# Mail (Botble Admin → Settings → Email can override)
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=info@serik.ca
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=
RESEND_VERIFIED_DOMAINS=serik.ca
RESEND_FORCE_SANDBOX_FROM=false

# TREB / AMP live fallback (also accepts TREB_AUTH alias in config/treb.php)
TRREB_AUTH=
TRREB_AUTH1=

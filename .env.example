APP_NAME=Serik
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=serik
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=file

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

GEOCODING_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_GEOCODING_API_KEY=

# Geo block: false = allow all countries (recommended while testing from PK)
GEO_BLOCK_ENABLED=false
GEO_BLOCK_ALLOWED_COUNTRIES=US,CA
GEO_BLOCK_BYPASS_IPS=

# Mail (Botble Admin → Settings → Email can override)
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=
